---
import Icon from './Icon.astro';
import { useT, type Lang } from '@i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useT(lang);
---

<footer class="bg-ink text-cream-100/85">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-16 grid sm:grid-cols-2 md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <div class="flex items-center gap-2.5">
        <span class="w-7 h-7 rounded-full bg-cream-50 text-ocean-800 grid place-items-center font-display text-[15px]">S</span>
        <span class="font-display text-[22px] text-cream-50">Villa Solana</span>
      </div>
      <p class="mt-4 text-cream-100/70 max-w-sm leading-relaxed">{t('footer.tag')}</p>
    </div>

    <div class="md:col-span-4">
      <div class="text-[11px] tracking-eyebrow uppercase text-cream-100/55 mb-3">{t('footer.reach')}</div>
      <ul class="space-y-2 text-[14px]">
        <li class="flex items-center gap-2"><Icon name="wa" class="w-4 h-4 text-ocean-200" /> {t('footer.phone')}</li>
        <li class="flex items-center gap-2"><Icon name="mail" class="w-4 h-4 text-ocean-200" /> {t('footer.mail')}</li>
        <li class="flex items-center gap-2"><Icon name="pin" class="w-4 h-4 text-ocean-200" /> {t('footer.addr')}</li>
      </ul>
    </div>

    <div class="md:col-span-3">
      <div class="text-[11px] tracking-eyebrow uppercase text-cream-100/55 mb-3">{t('footer.follow')}</div>
      <div class="flex items-center gap-2">
        {(['ig', 'fb', 'wa'] as const).map((i) => (
          <a
            href="#"
            aria-label={i}
            class="w-10 h-10 rounded-full border border-cream-50/15 hover:bg-cream-50 hover:text-ink transition grid place-items-center"
          >
            <Icon name={i} class="w-4 h-4" />
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="border-t border-cream-50/10">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-5 flex flex-wrap items-center justify-between gap-3 text-[12px] text-cream-100/55">
      <span>{t('footer.rights')}</span>
      <div class="flex items-center gap-5">
        <a href="#" class="hover:text-cream-50">Privacy</a>
        <a href="#" class="hover:text-cream-50">House rules</a>
        <a href="#" class="hover:text-cream-50">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
