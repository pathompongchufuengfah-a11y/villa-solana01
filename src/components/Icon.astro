{name === 'line' && (
  <svg viewBox="0 0 24 24" class={className} {...p}>
    <path d="M12 4c5 0 9 3.2 9 7.2 0 2.2-1.4 4.2-3.6 5.6-.4.2-.6.6-.5 1l.4 1.6c.1.3-.2.6-.5.4l-2.4-1.4c-.2-.1-.4-.1-.6-.1-.6.1-1.2.1-1.8.1-5 0-9-3.2-9-7.2S7 4 12 4z" />
