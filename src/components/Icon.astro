}
const { name, class: className = 'w-6 h-6' } = Astro.props;
const p = {
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': 1.4,
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
} as const;
---
{name === 'pool' && (
