---
import Icon from './Icon.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useT, localizedHref, type Lang } from '@i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useT(lang);

const items: { href: string; key: string }[] = [
  { href: localizedHref('/', lang), key: 'nav.home' },
  { href: localizedHref('/rooms', lang), key: 'nav.rooms' },
  { href: localizedHref('/amenities', lang), key: 'nav.amenities' },
  { href: localizedHref('/location', lang), key: 'nav.location' },
  { href: localizedHref('/contact', lang), key: 'nav.contact' },
];

const bookHref = localizedHref('/booking', lang);
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-40 transition-all duration-500 bg-transparent"
>
  <div class="max-w-7xl mx-auto px-5 sm:px-8 h-16 sm:h-20 flex items-center justify-between">
    <a href={localizedHref('/', lang)} class="flex items-center gap-2.5 group" aria-label="Villa Solana — Home">
      <span
        data-logo-mark
        class="w-7 h-7 rounded-full grid place-items-center font-display text-[15px] bg-cream-50 text-ocean-700"
      >S</span>
      <span
        data-logo-text
        class="font-display text-[19px] sm:text-[21px] leading-none text-cream-50"
      >Villa Solana</span>
    </a>

    <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
      {items.map((it) => (
        <a
          href={it.href}
          data-nav-link
          class="link-underline text-[13px] tracking-wide text-cream-100/95 hover:text-white transition"
        >{t(it.key)}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <LanguageSwitcher current={lang} />
      <a
        href={bookHref}
        data-nav-cta
        class="hidden sm:inline-flex items-center gap-2 text-[12.5px] tracking-wide px-4 py-2.5 rounded-full transition bg-cream-50 text-ocean-700 hover:bg-white"
      >
        {t('nav.booking')}
        <Icon name="arrow" class="w-3.5 h-3.5" />
      </a>
      <button
        type="button"
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded text-cream-50"
        aria-label="Menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden bg-cream-50 border-t hairline hidden">
    <div class="px-5 py-4 flex flex-col gap-3">
      {items.map((it) => (
        <a href={it.href} class="text-ink py-1.5 text-[15px]">{t(it.key)}</a>
      ))}
      <a
        href={bookHref}
        class="mt-1 inline-flex items-center justify-center gap-2 text-sm tracking-wide px-4 py-3 rounded-full bg-ocean-700 text-cream-50"
      >
        {t('nav.booking')}
        <Icon name="arrow" class="w-3.5 h-3.5" />
      </a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.getElementById('site-header');
    const mark = header?.querySelector('[data-logo-mark]');
    const text = header?.querySelector('[data-logo-text]');
    const cta = header?.querySelector('[data-nav-cta]');
    const links = header?.querySelectorAll('[data-nav-link]');
    if (!header) return;

    const onScroll = () => {
      const scrolled = window.scrollY > 24;
      header.classList.toggle('bg-cream-50/90', scrolled);
      header.classList.toggle('backdrop-blur', scrolled);
      header.classList.toggle('border-b', scrolled);
      header.classList.toggle('hairline', scrolled);

      if (mark) {
        mark.classList.toggle('bg-ocean-700', scrolled);
        mark.classList.toggle('text-cream-50', scrolled);
        mark.classList.toggle('bg-cream-50', !scrolled);
        mark.classList.toggle('text-ocean-700', !scrolled);
      }
      if (text) {
        text.classList.toggle('text-ink', scrolled);
        text.classList.toggle('text-cream-50', !scrolled);
      }
      if (cta) {
        cta.classList.toggle('bg-ocean-700', scrolled);
        cta.classList.toggle('text-cream-50', scrolled);
        cta.classList.toggle('hover:bg-ocean-800', scrolled);
        cta.classList.toggle('bg-cream-50', !scrolled);
        cta.classList.toggle('text-ocean-700', !scrolled);
        cta.classList.toggle('hover:bg-white', !scrolled);
      }
      links?.forEach((a) => {
        a.classList.toggle('text-ink-soft', scrolled);
        a.classList.toggle('hover:text-ocean-700', scrolled);
        a.classList.toggle('text-cream-100/95', !scrolled);
        a.classList.toggle('hover:text-white', !scrolled);
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      const open = menu?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }));
  })();
</script>
