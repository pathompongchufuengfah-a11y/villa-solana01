---
import { languages, localizedHref, getRouteFromUrl, type Lang } from '@i18n/utils';

interface Props {
  current: Lang;
  variant?: 'transparent' | 'solid';
}

const { current, variant = 'transparent' } = Astro.props;
const route = getRouteFromUrl(Astro.url);

const display: Record<Lang, string> = { en: 'EN', th: 'TH', ru: 'RU', zh: '中' };
const wrapCls = variant === 'solid'
  ? 'bg-cream-100 border hairline'
  : 'bg-white/10 border border-white/15';
---

<div class={`hidden sm:flex items-center rounded-full p-0.5 ${wrapCls}`} aria-label="Language">
  {(Object.keys(languages) as Lang[]).map((code) => {
    const isActive = code === current;
    const activeCls = variant === 'solid' ? 'bg-ocean-700 text-cream-50' : 'bg-cream-50 text-ocean-700';
    const inactiveCls = variant === 'solid' ? 'text-ink-mute hover:text-ink' : 'text-cream-50/85 hover:text-white';
    return (
      <a
        href={localizedHref(route, code)}
        hreflang={code}
        aria-current={isActive ? 'true' : undefined}
        class={`lang-btn ${isActive ? activeCls : inactiveCls}`}
      >
        {display[code]}
      </a>
    );
  })}
</div>
