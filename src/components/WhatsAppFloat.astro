---
import Icon from './Icon.astro';

const phone = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '66812345678';
const message = encodeURIComponent('Hi! I’d like to ask about Villa Solana.');
const href = `https://wa.me/${phone}?text=${message}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat on WhatsApp"
  class="fixed bottom-5 right-5 z-30 w-14 h-14 rounded-full bg-[#25D366] text-white grid place-items-center shadow-soft hover:scale-105 transition"
>
  <Icon name="wa" class="w-7 h-7" />
</a>
