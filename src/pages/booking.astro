---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import BookingForm from '@components/BookingForm.astro';
import Icon from '@components/Icon.astro';
import { useT, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useT(lang);
---

<BaseLayout
  title="Reserve — Villa Solana Phuket"
  description="Request a stay at Villa Solana. We reply within 2 hours, 7 days a week. No card needed to enquire."
>
  <section class="pt-32 sm:pt-40 pb-24 bg-ocean-800 text-cream-50">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-5">
        <SectionHeading
          eyebrow={t('book.eyebrow')}
          title={t('book.title')}
          sub={t('book.sub')}
          tone="light"
        />

        <div class="mt-10 rounded-2xl bg-ocean-700/40 border border-ocean-400/20 p-6">
          <div class="flex items-baseline justify-between">
            <span class="text-[11px] tracking-eyebrow uppercase text-ocean-200">{t('book.perNight')}</span>
            <span class="font-display text-3xl">฿8,500</span>
          </div>
          <div class="mt-3 h-px bg-cream-50/10"></div>
          <div class="mt-3 text-[13px] text-cream-100/80 leading-relaxed">{t('book.rateNote')}</div>
        </div>

        <p class="mt-8 text-[12px] tracking-eyebrow uppercase text-ocean-200">Or message us directly</p>
        <div class="mt-3 flex items-center gap-5 flex-wrap text-cream-100/80 text-[13px]">
          <a href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '66812345678'}`} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-white">
            <Icon name="wa" class="w-4 h-4" /> WhatsApp
          </a>
          <a href={`https://line.me/R/ti/p/${import.meta.env.PUBLIC_LINE_ID ?? '@villasolana'}`} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-white">
            <Icon name="line" class="w-4 h-4" /> LINE
          </a>
          <a href={import.meta.env.PUBLIC_FACEBOOK_URL ?? 'https://m.me/villasolana'} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-white">
            <Icon name="fb" class="w-4 h-4" /> Facebook
          </a>
          <a href="mailto:stay@villasolana.example" class="inline-flex items-center gap-2 hover:text-white">
            <Icon name="mail" class="w-4 h-4" /> Email
          </a>
        </div>
      </div>

      <div class="lg:col-span-7">
        <BookingForm lang={lang} />
      </div>
    </div>
  </section>
</BaseLayout>
