---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import Icon from '@components/Icon.astro';
import { useT, getLangFromUrl } from '@i18n/utils';
import { ui } from '@i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useT(lang);
const nearby = t<typeof ui.en.location.nearby>('location.nearby');

const embedUrl =
  import.meta.env.PUBLIC_GMAPS_EMBED_URL ??
  // Default: a Chalong-area embed. Replace with the villa's actual share URL.
  'https://www.google.com/maps?q=Chalong%20Phuket&output=embed';
---

<BaseLayout
  title="Location — Villa Solana Phuket"
  description="In Chalong, ten minutes to anywhere. Beaches, Big Buddha, the marina, and Old Town all in driving distance."
>
  <section class="pt-32 sm:pt-40 pb-12 bg-cream-50">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <SectionHeading
        eyebrow={t('location.eyebrow')}
        title={t('location.title')}
        sub={t('location.sub')}
      />
    </div>
  </section>

  <section class="reveal pb-24 bg-cream-50">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-5">
        <ul class="divide-y hairline border-y hairline">
          {nearby.map((n) => (
            <li class="flex items-center justify-between py-3.5">
              <div class="flex items-center gap-3">
                <Icon name="pin" class="w-4 h-4 text-ocean-700" />
                <span class="text-ink text-[15px]">{n.t}</span>
              </div>
              <span class="text-ink-mute text-[13px] tracking-wide">{n.m}</span>
            </li>
          ))}
        </ul>

        <div class="mt-10 rounded-2xl bg-cream-100/70 border hairline p-6">
          <div class="text-[11px] tracking-eyebrow uppercase text-ocean-700">{t('location.gettingHere')}</div>
          <p class="mt-3 text-ink-soft text-[14.5px] leading-relaxed">{t('location.transferNote')}</p>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="aspect-[5/4] sm:aspect-[16/11] rounded-2xl overflow-hidden border hairline bg-cream-100">
          <iframe
            src={embedUrl}
            title={t('location.mapTitle')}
            width="100%"
            height="100%"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
        <p class="mt-3 text-[12px] text-ink-mute">{t('location.privacy')}</p>
      </div>
    </div>
  </section>
</BaseLayout>
