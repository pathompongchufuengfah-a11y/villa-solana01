---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import GalleryGrid from '@components/GalleryGrid.astro';
import Icon from '@components/Icon.astro';
import { useT, getLangFromUrl, localizedHref } from '@i18n/utils';
import { ui } from '@i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useT(lang);
const rooms = t<typeof ui.en.rooms.list>('rooms.list');

const roomImages: Record<string, string> = {
  'Master suite': 'https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&w=1400&q=80',
  'Garden room': 'https://images.unsplash.com/photo-1505691938895-1758d7feb511?auto=format&fit=crop&w=1400&q=80',
  'Twin room': 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80',
};

const galleryItems = Object.entries(roomImages).map(([label, src]) => ({ src, label }));
---

<BaseLayout
  title="Rooms — Villa Solana Phuket"
  description="Three air-conditioned bedrooms sleeping six. Each opens onto the pool deck or garden."
>
  <section class="pt-32 sm:pt-40 pb-12 bg-cream-50">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <SectionHeading
        eyebrow={t('rooms.eyebrow')}
        title={t('rooms.title')}
        sub={t('rooms.sub')}
      />
    </div>
  </section>

  <section class="reveal py-12 sm:py-16 bg-cream-50">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 grid gap-10">
      {rooms.map((r, i) => (
        <article class={`grid md:grid-cols-12 gap-8 items-center ${i % 2 === 1 ? 'md:[direction:rtl]' : ''}`}>
          <div class="md:col-span-7 [direction:ltr]">
            <div class="aspect-[16/11] rounded-2xl overflow-hidden">
              <img
                src={roomImages[r.name]}
                alt={r.name}
                loading="lazy"
                decoding="async"
                width="1400"
                height="963"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
          <div class="md:col-span-5 [direction:ltr]">
            <div class="text-[11px] tracking-eyebrow uppercase text-ocean-700">{r.sleeps}</div>
            <h2 class="mt-2 font-display text-4xl text-ink leading-tight">{r.name}</h2>
            <p class="mt-4 text-ink-mute leading-relaxed">{r.d}</p>
            <a
              href={localizedHref('/booking', lang)}
              class="mt-6 inline-flex items-center gap-2 text-[13px] tracking-wide text-ocean-700 hover:text-ocean-800"
            >
              {t('rooms.reserve')} <Icon name="arrow" class="w-3.5 h-3.5" />
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="reveal py-24 sm:py-32 bg-cream-100/60">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <SectionHeading eyebrow={t('rooms.photos')} title={t('rooms.inside')} />
      <div class="mt-10">
        <GalleryGrid items={galleryItems} layout="even" />
      </div>
    </div>
  </section>
</BaseLayout>
