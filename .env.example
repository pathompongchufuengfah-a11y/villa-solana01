# --- Booking notifications (server-only secrets) ---
# LINE Notify token (https://notify-bot.line.me/my/)
LINE_NOTIFY_TOKEN=

# Forward enquiries to this inbox (used by /api/booking)
BOOKING_EMAIL_TO=stay@villasolana.example

# Resend.com transactional email (optional, used if set)
RESEND_API_KEY=

# --- Supabase (booking storage + admin queue) ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Service-role key (Settings → API). SERVER-ONLY — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin dashboard (/admin) ---
# The password you type to log into /admin
ADMIN_PASSWORD=change-me-please
# Random long string used to sign the admin session cookie.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# --- Public (exposed to client) ---
PUBLIC_CALENDLY_URL=https://calendly.com/villa-solana/site-visit
PUBLIC_WHATSAPP_NUMBER=66812345678
PUBLIC_LINE_ID=@villasolana
PUBLIC_GMAPS_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3956.8!2d98.345!3d7.842!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zN8KwNTAnMzEuMiJOIDk4wrAyMCc0Mi4wIkU!5e0!3m2!1sen!2sth!4v0000000000000
